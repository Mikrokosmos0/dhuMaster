%%%%%%%%%%%%%%% 重写题目（封面） %%%%%%%%%%%%%%%
% 封面页：奇数页页眉与正文一致（“东华大学硕士学位论文”居中），
% 封面对应的偶数页页眉不显示章标题（\leftmark 置空），正文偶数页仍显示章标题。
\newcommand{\reTitle}[1]{%
    \thispagestyle{fancy}%
    \markboth{}{}% 清空当前 mark，使紧接的偶数页 \leftmark 为空
    \begin{center}
        ~\par
        \heiti{\fontsize{16pt}{19.2pt}\selectfont #1}\\
        ~\par
    \end{center}
}
\newcommand{\reTitleEN}[1]{%
    \thispagestyle{fancy}%
    \markboth{}{}% 清空当前 mark，使紧接的偶数页 \leftmark 为空
    \begin{center}
        ~\par
        \textbf{\fontsize{16pt}{19.2pt}\selectfont #1}\\
        ~\par
    \end{center}
}

%%%%%%%%%%%%%%% 重写摘要 %%%%%%%%%%%%%%%
% 中文摘要：
% - “摘 要”中间空一格，黑体三号，段前段后 0 行，单倍行距
% - “摘 要”与内容之间空一行
% - 摘要内容：宋体小四，英文 Times New Roman，1.25 倍行距
\newcommand{\reAbstract}{%
    \phantomsection\addcontentsline{toc}{section}{摘\quad 要}%
    \par
    {\centering
        \heiti{\fontsize{16pt}{16pt}\selectfont 摘\hspace{1em}要}\par
    }%
    % “摘 要”与内容之间空一行
    \vspace{\baselineskip}%
    % 摘要内容局部设置：宋体小四，1.25 倍行距，首行缩进 2 字符
    \songti\fontsize{12pt}{15pt}\selectfont
    \setstretch{1.25}%
    \setlength{\parindent}{2\ccwd}%
}

% 英文摘要：
% - 英文题目：三号居中，全大写，Times New Roman 加粗，段前段后 0.7cm
%   （具体排版由 \reTitleEN 控制，这里只控制 “ABSTRACT” 及以下）
% - “ABSTRACT”：三号居中，Times New Roman 加粗，段前段后 0cm
% - ABSTRACT 与摘要内容之间空一行
% - 摘要内容：每段开头留四个字符空格，Times New Roman，11 号字，1.25 倍行距
\newcommand{\reAbstractEN}{%
    \phantomsection\addcontentsline{toc}{section}{ABSTRACT}%
    {\centering
        \textbf{\fontsize{16pt}{16pt}\selectfont ABSTRACT}\par
    }%
    % ABSTRACT 与内容之间空一行
    \vspace{\baselineskip}%
    % 英文摘要内容局部设置：Times New Roman，11pt，1.25 倍行距，首行缩进约 4 字符
    \normalfont\rmfamily\fontsize{11pt}{13.75pt}\selectfont
    \setstretch{1.25}%
    \setlength{\parindent}{2\ccwd}%
}

%%%%%%%%%%%%%%% 重写关键词 %%%%%%%%%%%%%%%
\newcommand{\reKeyword}[1]{%
    ~\par
    \noindent \heiti{\fontsize{12pt}{14.4pt}\selectfont 关键词：}%
    \songti{\fontsize{12pt}{14.4pt}\selectfont #1}%
    \newpage
}
\newcommand{\reKeywordEN}[1]{%
    ~\par
    \noindent \textbf{\fontsize{12pt}{14.4pt}\selectfont Key words: }#1%
    \newpage
}

%%%%%%%%%%%%%%% 设置各级标题格式 %%%%%%%%%%%%%%%
% 1. 目录题目（目录、图录、表录）：黑体三号，居中，段前/后 0.7cm，单倍行距
% 2. 章标题（第 x 章）：黑体三号，居中，段前/后 0.7cm，单倍行距
% 3. 节标题（x.x）：黑体四号，左对齐，段前/后 0.7cm，单倍行距
% 4. 条标题（x.x.x）：黑体小四号，左对齐，段前/后 0.3cm，单倍行距

% 章标题不显示序号（如 1、2、3），仅显示标题文字
\titleformat{\section}
  {\centering\fontsize{16pt}{16pt}\heiti\bfseries}
  {}{0pt}{}
\titlespacing*{\section}{0pt}{0.7cm}{0.7cm}

% 目录中章标题不显示序号（1、2、3、4）：\numberline 在 TOC 中吞掉序号
\makeatletter
% 调整目录中点阵省略号密度，默认约 4.5，调小则更密
\renewcommand{\@dotsep}{1.5}
% 重定义 article 类的 \l@section 使其带有引导点（不加粗），并且不显示序号
\def\l@section#1#2{%
    \@dottedtocline{1}{0em}{0em}{\begingroup\let\numberline\@gobble#1\endgroup}{#2}%
}
\makeatother

\titleformat{\subsection}
  {\fontsize{14pt}{14pt}\heiti\bfseries\rmfamily}
  {\thesubsection}{0.5em}{}
\titlespacing*{\subsection}{0pt}{0.7cm}{0.7cm}

\titleformat{\subsubsection}
  {\fontsize{12pt}{12pt}\heiti\bfseries\rmfamily}
  {\thesubsubsection}{0.5em}{}
\titlespacing*{\subsubsection}{0pt}{0.7cm}{0.7cm}

%%%%%%%%%%%%%%% 重写一级标题（章节） %%%%%%%%%%%%%%%
\newcommand{\reSection}[1]{%
    \newpage
    \section{#1}%
}

%%%%%%%%%%%%%%% 有序列表 %%%%%%%%%%%%%%%
\newcommand{\orderedList}[1]{%
    \begin{enumerate}[\hspace{2em} (1)]
        #1
    \end{enumerate}
}

%%%%%%%%%%%%%%% 数学环境设置 %%%%%%%%%%%%%%%
\numberwithin{equation}{section}
\renewcommand{\theequation}{\thesection{}-\arabic{equation}}

\newtheorem{example}{例}
\newtheorem{algorithm}{算法}
\newtheorem{theorem}{定理}[section]
\newtheorem{definition}{定义}
\newtheorem{axiom}{公理}
\newtheorem{property}{性质}
\newtheorem{proposition}{命题}
\newtheorem{lemma}{引理}
\newtheorem{corollary}{推论}
\newtheorem{remark}{注解}
\newtheorem{condition}{条件}
\newtheorem{conclusion}{结论}
\newtheorem{assumption}{假设}

%%%%%%%%%%%%%%% 图片与表格环境设置（双语与细化规范） %%%%%%%%%%%%%%%
\counterwithin{figure}{section}
\renewcommand{\thefigure}{\thesection{}-\arabic{figure}}

\counterwithin{table}{section}
\renewcommand{\thetable}{\thesection{}-\arabic{table}}

% 自定义标签格式：去除编号与名称之间的空格（如：图1-1）
\DeclareCaptionLabelFormat{dhuLabel}{#1#2}
% 自定义分隔符
\DeclareCaptionLabelSeparator{rparen}{) }

% 全局图表题格式设置（五号 10.5pt，单倍行距，居中）
\captionsetup{
    labelformat=dhuLabel,   % 使用自定义格式去除空格
    font={small},           % 五号 10.5pt
    labelfont={bf},         % 标签加粗
    labelsep=quad,          % 编号与标题间空一格
    justification=centering,
    singlelinecheck=off,
    font={small, stretch=1.0} % 单倍行距
}

% 针对图的特殊间距设置
\captionsetup[figure]{
    position=bottom,
    skip=10pt,              % 图与图题的间距
    belowskip=12pt          % 图题下方的间距（对应“空一行”）
}

% 针对表的特殊间距设置
\captionsetup[table]{
    position=top,
    skip=10pt,
    belowskip=10pt
}

% 双语图题设置 (bicaption)
% 绕过 bi-separator 兼容性问题，直接在第二语言名称中加入换行
\captionsetup[figure][bi-first]{name=图}
\captionsetup[figure][bi-second]{name={\\ Fig}} % 在英文前缀前强制换行
\captionsetup[table][bi-first]{name=表}
\captionsetup[table][bi-second]{name={\\ Table}}

% 分图题设置：置于分图之下，分图号用 a)、b)
\captionsetup[subfigure]{
    labelformat=simple,
    labelsep=rparen,        % 分图号后面带括弧 a)
    font={small},
    justification=centering
}
\renewcommand{\thesubfigure}{\alph{subfigure}} % a, b, c...

% 定义一个方便的快捷命令，用于右上角标引文献（图题引用）
\newcommand{\citecaption}[1]{\textsuperscript{\cite{#1}}}

%%%%%%%%%%%%%%% 参考文献 %%%%%%%%%%%%%%%
\newlength{\bibitemsep}\setlength{\bibitemsep}{.01\baselineskip plus .005\baselineskip minus .005\baselineskip}
\newlength{\bibparskip}\setlength{\bibparskip}{0pt}
\let\oldthebibliography\thebibliography
\renewcommand\thebibliography[1]{%
    \oldthebibliography{#1}%
    \setlength{\parskip}{\bibitemsep}%
    \setlength{\itemsep}{\bibparskip}%
}

\xpatchcmd{\oldthebibliography}{\section*}{\section}{}{}
\newcommand{\reference}[1]{%
    \begin{thebibliography}{99}
        #1
    \end{thebibliography}
}

%%%%%%%%%%%%%%% 致谢 %%%%%%%%%%%%%%%
% 正文后的题目（致谢）——复用章节标题格式
\newcommand{\reThanks}[1]{%
    \newpage
    \addcontentsline{toc}{section}{致谢}%
    \section*{致谢}%
    #1%
}

